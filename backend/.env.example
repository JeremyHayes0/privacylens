# Copy this file to `.env` and fill in real values for local development.
# `.env` itself must never be committed -- only `.env.example` is checked
# into source control.

# --- Database ---
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://privacylens:privacylens@localhost:5432/privacylens

# --- Queue (scan worker) ---
# Points the API (enqueueing scans) and the worker process
# (worker_entrypoint.py, consuming them) at the same Redis instance.
REDIS_URL=redis://localhost:6379/0

# --- JWT / Auth ---
# Generate a strong random secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Never reuse this placeholder value outside of local development.
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- App ---
ENVIRONMENT=development
